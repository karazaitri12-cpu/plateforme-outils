{
  "rewrites": [
    {
      "source": "/tools/:path*/index.html",
      "destination": "/tools/:path*/index.html"
    },
    {
      "source": "/tools/:folder([a-zA-Z0-9_-]+)/",
      "destination": "/tools/wrapper.html"
    },
    {
      "source": "/tools/:folder([a-zA-Z0-9_-]+)",
      "destination": "/tools/wrapper.html"
    }
  ]
}
