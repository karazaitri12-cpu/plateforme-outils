{
  "rewrites": [
    {
      "source": "/tools/:folder((?!wrapper|index)[a-zA-Z0-9_-]+)/",
      "destination": "/tools/wrapper.html"
    },
    {
      "source": "/tools/:folder((?!wrapper|index)[a-zA-Z0-9_-]+)",
      "destination": "/tools/wrapper.html"
    }
  ],
  "redirects": [
    {
      "source": "/tools/:folder((?!wrapper|index)[a-zA-Z0-9_-]+)/index.html",
      "destination": "/tools/:folder/"
    }
  ]
}
